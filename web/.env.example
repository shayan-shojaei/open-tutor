# Set to "hosted" to enable hosted mode (auth, backend API, etc.)
# Leave unset for local mode (default behavior, no auth required)
NEXT_PUBLIC_APP_MODE=

# Backend server URL (required when NEXT_PUBLIC_APP_MODE=hosted)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Required when NEXT_PUBLIC_APP_MODE=hosted
AUTH_SECRET=                        # Same value as JWT_SECRET in server/.env
AUTH_URL=http://localhost:3000

# OAuth providers (required when NEXT_PUBLIC_APP_MODE=hosted)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Database (required when NEXT_PUBLIC_APP_MODE=hosted — same DB as server)
DATABASE_URL=postgresql://opentutor:opentutor@postgres:5432/opentutor
